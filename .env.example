# EverClean client environment
NEXT_PUBLIC_API_URL=https://commercial-clean-setup.replit.app/api

# Browser-safe Google Maps JavaScript key for the pro coverage map.
# Enable Maps JavaScript API and Geocoding API in Google Cloud.
# Restrict this key by HTTP referrer to your Vercel domains.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional notification providers. When empty, booking notifications are skipped safely.
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@everclean.app
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=notifications@everclean.app
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
